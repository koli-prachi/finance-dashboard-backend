                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:9090/dashboard/summary",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "dashboard",
                "summary"
              ]
            },
            "description": "Returns overall financial summary including total income, total expense, and net balance.  \nUsed to provide a quick overview of financial status."
          },
          "response": []
        },
        {
          "name": "Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:9090/dashboard/category",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "dashboard",
                "category"
              ]
            },
            "description": "Returns aggregated financial data grouped by category.  \nHelps visualize how expenses or income are distributed across different categories."
          },
          "response": []
        },
        {
          "name": "Trends",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:9090/dashboard/trends",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "9090",
              "path": [
                "dashboard",
                "trends"
              ]
            },
